        "command": "cursorLineStartSelect",
        "when": "textInputFocus && editorLangId != 'clojure'"
    },
    {
        "key": "ctrl+shift+a",
        "command": "-cursorLineStartSelect",
        "when": "textInputFocus"
    },
    {
        "key": "ctrl+shift+l",
        "command": "cursorLineEndSelect",
        "when": "textInputFocus && editorLangId != 'clojure'"
    },
    {
        "key": "ctrl+shift+e",
        "command": "-cursorLineEndSelect",
