        "when": "editorTextFocus"
    },
    {
        "key": "shift+[Equal]",
        "command": "deleteRight",
        "when": "textInputFocus && editorLangId == 'clojure'"
    },
    {
        "key": "ctrl+shift+alt+cmd+[Semicolon]",
        "command": "cursorBottomSelect",
        "when": "textInputFocus"
    },
    {
        "key": "shift+cmd+down",
        "command": "-cursorBottomSelect",
        "when": "textInputFocus"
    },
    {
        "key": "ctrl+shift+alt+cmd+p",
        "command": "cursorTopSelect",
        "when": "textInputFocus"
    },
    {
        "key": "shift+cmd+up",
        "command": "-cursorTopSelect",
        "when": "textInputFocus"
    },
    {
        "key": "ctrl+7",
        "command": "-workbench.action.openEditorAtIndex7"
    },
    {
        "key": "cmd+8",
        "command": "calva.showOutputWindow"
    },
    {
        "key": "cmd+7",
        "command": "-workbench.action.focusSeventhEditorGroup"
    },
    {
        "key": "ctrl+[BracketRight]",
        "command": "workbench.action.increaseViewWidth"
    },
    {
        "key": "ctrl+-",
        "command": "workbench.action.decreaseViewWidth"
    },
    {
        "key": "ctrl+alt+[BracketRight]",
        "command": "workbench.action.increaseViewHeight"
    },
    {
        "key": "ctrl+alt+-",
        "command": "workbench.action.decreaseViewHeight"
    },
    {
        "key": "shift+enter",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\\\r\n"
        },
        "when": "terminalFocus"
    },
    {
        "key": "cmd+escape",
        "command": "-claude-vscode.editor.open",
        "when": "!config.claude-code.useTerminal"
    },
    {
        "key": "shift+alt+c",
        "command": "claude-vscode.editor.open"
    },
    {
        "key": "alt+cmd+m alt+cmd+m",
        "command": "saveEditorLayout.toggleBookmark"
    },
    {
        "key": "alt+cmd+[Period]",
        "command": "saveEditorLayout.nextBookmark"
    },
    {
        "key": "alt+cmd+[Period]",
        "command": "-github.copilot.chat.rerunWithCopilotDebug",
        "when": "github.copilot-chat.activated && terminalFocus && terminalShellIntegrationEnabled && !terminalAltBufferActive"
    },
    {
        "key": "alt+cmd+[Period]",
        "command": "-editor.action.autoFix",
